check_remote_script() {
  cat <<'EOF'
warn=0
echo "hostname: $(hostname)"
echo "user: $(whoami)"
if command -v sudo >/dev/null 2>&1; then
  if sudo -n true 2>/dev/null; then
    echo "sudo: ok (免密可用)"
  else
    echo "sudo: 需要密码或不可用"
  fi
else
  echo "sudo: 未安装"
fi

disk_used="$(df -P / | awk 'NR==2 {gsub("%","",$5); print $5}')"
if [ -n "$disk_used" ]; then
  echo "disk /: ${disk_used}%"
  if [ "$disk_used" -ge 85 ]; then
    echo "warning: 根分区超过 85%"
    warn=1
  fi
fi

mem_available="$(awk '/MemAvailable/ {printf "%.0f", $2/1024}' /proc/meminfo 2>/dev/null)"
if [ -n "$mem_available" ]; then
  echo "memory available: ${mem_available} MB"
  if [ "$mem_available" -lt 200 ]; then
    echo "warning: 可用内存低于 200 MB"
    warn=1
  fi
else
  echo "memory available: unknown"
fi

if command -v systemctl >/dev/null 2>&1; then
  for svc in sshd ssh nginx docker cron; do
    state="$(systemctl is-active "$svc" 2>/dev/null || true)"
    if [ -n "$state" ]; then
      echo "service ${svc}: ${state}"
      if [ "$state" = "failed" ]; then
        warn=1
      fi
    fi
  done
fi

exit "$warn"
EOF
}

