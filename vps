[ -n "${tx_bytes}" ] || tx_bytes=0
rx_value="$(format_bytes_iec "${rx_bytes}")"
tx_value="$(format_bytes_iec "${tx_bytes}")"

cc_value="$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo "-")"
qdisc_value="$(sysctl -n net.core.default_qdisc 2>/dev/null || echo "-")"
