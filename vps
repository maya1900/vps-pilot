}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "${value}"
}

expand_home() {
  local value="$1"
  if [[ "${value}" == "~"* ]]; then
    printf '%s\n' "${HOME}${value:1}"
  else
    printf '%s\n' "${value}"
  fi
}

find_server() {
  local target="$1"
  local line

  while IFS= read -r line || [[ -n "${line}" ]]; do
    line="$(trim "${line}")"
    [[ -z "${line}" || "${line}" == \#* ]] && continue
    IFS='|' read -r name _ <<<"${line}"
    name="$(trim "${name}")"
    if [[ "${name}" == "${target}" ]]; then
      printf '%s\n' "${line}"
      return 0
    fi
  done < "${CONFIG_FILE}"

  return 1
}

parse_server() {
  local line="$1"

  IFS='|' read -r SERVER_NAME SERVER_USER SERVER_HOST SERVER_PORT SERVER_KEY <<<"${line}"
  SERVER_NAME="$(trim "${SERVER_NAME}")"
  SERVER_USER="$(trim "${SERVER_USER}")"
  SERVER_HOST="$(trim "${SERVER_HOST}")"
  SERVER_PORT="$(trim "${SERVER_PORT}")"
  SERVER_KEY="$(trim "${SERVER_KEY}")"

  SERVER_PORT="${SERVER_PORT:-22}"
  SERVER_KEY="${SERVER_KEY:--}"
  if [[ "${SERVER_KEY}" != "-" ]]; then
    SERVER_KEY="$(expand_home "${SERVER_KEY}")"
  fi
}

ssh_args_for_current_server() {
  local mode="${1:-serial}"

  CURRENT_SSH_ARGS=(
    -p "${SERVER_PORT}"
    -o ConnectTimeout=8
    -o ServerAliveInterval=15
    -o ServerAliveCountMax=2
    -o StrictHostKeyChecking=accept-new
  )
  if [[ "${mode}" == "parallel" ]]; then
    CURRENT_SSH_ARGS+=(-n -o BatchMode=yes)
  fi
  if [[ "${SERVER_KEY}" != "-" ]]; then
    CURRENT_SSH_ARGS+=(-i "${SERVER_KEY}")
  fi
}

run_remote_command() {
  local line="$1"
  local remote_cmd="$2"
  local mode="${3:-serial}"
  local ssh_status

  parse_server "${line}"
  ssh_args_for_current_server "${mode}"

  print_rule
  printf '%s %s %s\n' "$(style_text "${STYLE_LABEL}" ">>>")" "$(style_text "${STYLE_VALUE}" "${SERVER_NAME}")" "$(style_text "${STYLE_MUTED}" "(${SERVER_USER}@${SERVER_HOST})")"
  set +e
  ssh "${CURRENT_SSH_ARGS[@]}" "${SERVER_USER}@${SERVER_HOST}" "${remote_cmd}"
  ssh_status=$?
  set -e
  if [[ ${ssh_status} -eq 0 ]]; then
    printf '%s %s\n' "$(format_status_label "[OK]" "ok")" "$(style_text "${STYLE_VALUE}" "${SERVER_NAME}")"
  else
    printf '%s %s %s\n' "$(format_status_label "[FAIL:${ssh_status}]" "fail")" "$(style_text "${STYLE_VALUE}" "${SERVER_NAME}")" "$(style_text "${STYLE_MUTED}" "请看上面的输出")"
  fi
  echo
  return "${ssh_status}"
}

capture_remote_command() {
  local line="$1"
  local remote_cmd="$2"
  local mode="${3:-serial}"

  parse_server "${line}"
  ssh_args_for_current_server "${mode}"

  set +e
  CAPTURED_REMOTE_OUTPUT="$(ssh "${CURRENT_SSH_ARGS[@]}" "${SERVER_USER}@${SERVER_HOST}" "${remote_cmd}" 2>&1)"
  CAPTURED_REMOTE_STATUS=$?
  set -e
}

each_server() {
  local line

  while IFS= read -r line || [[ -n "${line}" ]]; do
    line="$(trim "${line}")"
    [[ -z "${line}" || "${line}" == \#* ]] && continue
    printf '%s\n' "${line}"
  done < "${CONFIG_FILE}"
}

