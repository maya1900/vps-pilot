#!/usr/bin/env bash
set -euo pipefail

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [[ -L "${source}" ]]; do
    local dir
    dir="$(cd "$(dirname "${source}")" && pwd)"
    source="$(readlink "${source}")"
    [[ "${source}" != /* ]] && source="${dir}/${source}"
  done
  cd "$(dirname "${source}")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
CONFIG_FILE="${VPSCTL_CONFIG:-${SCRIPT_DIR}/servers.conf}"
HISTORY_FILE="${VPSCTL_HISTORY_FILE:-${SCRIPT_DIR}/.vps_batch_history}"
APP_NAME="VPS Pilot"
APP_VERSION="v0.0.1"
APP_AUTHOR="markyal"
APP_CMD="vps"
APP_QUICK_HINT="list | ssh <name> | status | batch all | containers <name>"

if ! command -v ssh >/dev/null 2>&1; then
  echo "缺少 ssh 命令，先安装 OpenSSH 客户端。"
  exit 1
fi

if [[ -t 1 ]]; then
  STYLE_RESET=$'\033[0m'
  STYLE_TITLE=$'\033[1;36m'
  STYLE_LABEL=$'\033[1;33m'
  STYLE_HINT=$'\033[2m'
else
  STYLE_RESET=""
  STYLE_TITLE=""
  STYLE_LABEL=""
  STYLE_HINT=""
fi

BATCH_HISTORY_COUNT=0
BATCH_HISTORY_ITEMS=()
CAPTURED_REMOTE_OUTPUT=""
CAPTURED_REMOTE_STATUS=0
CONTAINER_LINES=()
SELECTED_CONTAINER=""

usage() {
  cat <<EOF
${APP_NAME} ${APP_VERSION}
by ${APP_AUTHOR}

直接输入:
  ${APP_CMD}

常用命令:
  ${APP_CMD} list
  ${APP_CMD} ssh <name>
