  fi
fi
EOF
}

heuristic_doctor_analysis() {
  local report="$1"
  local lower
  local -a findings=()
  local -a suggestions=()
  local i

  lower="$(printf '%s' "${report}" | tr '[:upper:]' '[:lower:]')"

  if [[ "${lower}" == *"no space left on device"* || "${lower}" == *"disk /:"*85* || "${lower}" == *"disk /:"*90* ]]; then
    findings+=("磁盘空间很可能顶满了，服务写日志或写临时文件时会直接报错。")
    suggestions+=("先看 df -h，再用 du -sh /* 2>/dev/null | sort -h 找大目录。")
  fi

  if [[ "${lower}" == *"oom"* || "${lower}" == *"out of memory"* || "${lower}" == *"killed process"* ]]; then
    findings+=("机器出现了内存压力，进程可能被系统直接杀掉。")
    suggestions+=("先看 free -h、dmesg 或 journalctl，再决定是限流、重启服务还是加 swap。")
  fi

  if [[ "${lower}" == *"address already in use"* || "${lower}" == *"bind:"* ]]; then
    findings+=("端口冲突，已经有别的进程占住了目标端口。")
    suggestions+=("用 ss -tulpn 定位占用进程，再决定换端口还是停掉旧进程。")
  fi

  if [[ "${lower}" == *"permission denied"* ]]; then
    findings+=("权限不够，常见于文件权限、目录属主或 SELinux/AppArmor 限制。")
    suggestions+=("先检查 ls -l、id、systemctl status，对照服务运行用户排查。")
  fi

  if [[ "${lower}" == *"unit "* && "${lower}" == *"could not be found"* ]]; then
    findings+=("指定的 systemd 服务名不存在，可能服务实际名字写错了，或者这个服务本来就跑在容器里。")
    suggestions+=("先执行 systemctl list-units --type=service | grep -i 关键字，或者改查对应容器日志。")
  fi

  if [[ "${lower}" == *"connection refused"* || "${lower}" == *"failed to connect"* ]]; then
    findings+=("连接被拒绝，通常是上游服务没起来、监听地址不对，或者防火墙拦了。")
    suggestions+=("确认目标服务是否在监听端口，再检查配置里的 host/port 和防火墙规则。")
  fi

  if [[ "${lower}" == *"502 bad gateway"* || "${lower}" == *"upstream prematurely closed connection"* ]]; then
    findings+=("像是反向代理到上游应用之间出问题了，Nginx 只是表象。")
    suggestions+=("先看 Nginx 错误日志，再看上游应用进程和容器日志。")
  fi

  if [[ "${lower}" == *"module not found"* || "${lower}" == *"command not found"* || "${lower}" == *"no such file or directory"* ]]; then
    findings+=("依赖、二进制或路径配置不完整。")
    suggestions+=("检查启动命令、环境变量、工作目录，以及最近是否改过部署路径。")
  fi

  echo "==== 本地规则分析 ===="
  if [[ ${#findings[@]} -eq 0 ]]; then
    echo "暂时没命中明显的报错特征，但原始诊断信息已经抓下来了，适合继续做人工排查或 AI 分析。"
    return 0
  fi

  for ((i=0; i<${#findings[@]}; i++)); do
    printf '[%d] %s\n' "$((i + 1))" "${findings[$i]}"
    printf '    建议: %s\n' "${suggestions[$i]}"
  done
}

