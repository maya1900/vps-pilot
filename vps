copy_key() {
  local target="$1"
  local pubkey="${HOME}/.ssh/id_ed25519.pub"
  local line

  if [[ ! -f "${pubkey}" ]]; then
    echo "没找到公钥: ${pubkey}"
    echo "先执行: ssh-keygen -t ed25519"
    exit 1
  fi

  if ! line="$(find_server "${target}")"; then
    echo "没找到服务器: ${target}"
    exit 1
  fi

  parse_server "${line}"
  ssh_args_for_current_server "serial"
  ssh "${CURRENT_SSH_ARGS[@]}" "${SERVER_USER}@${SERVER_HOST}" \
    "umask 077 && mkdir -p ~/.ssh && touch ~/.ssh/authorized_keys && cat > ~/.ssh/vps_tmp_key && (grep -qxFf ~/.ssh/vps_tmp_key ~/.ssh/authorized_keys || cat ~/.ssh/vps_tmp_key >> ~/.ssh/authorized_keys) && rm -f ~/.ssh/vps_tmp_key" \
    < "${pubkey}"
  echo "公钥已写入 ${SERVER_NAME}"
}

build_managed_ssh_config_block() {
  local line

  printf '%s\n' "${SSH_CONFIG_BEGIN}"
  printf '%s\n' "# generated by ${APP_NAME} ${APP_VERSION}"
  while IFS= read -r line; do
    parse_server "${line}"
    printf '%s\n' "Host ${SERVER_NAME}"
    printf '%s\n' "  HostName ${SERVER_HOST}"
    printf '%s\n' "  User ${SERVER_USER}"
    printf '%s\n' "  Port ${SERVER_PORT}"
    printf '%s\n' "  ServerAliveInterval 15"
    printf '%s\n' "  ServerAliveCountMax 2"
    printf '%s\n' "  StrictHostKeyChecking accept-new"
    if [[ "${SERVER_KEY}" != "-" ]]; then
      printf '%s\n' "  IdentityFile ${SERVER_KEY}"
      printf '%s\n' "  IdentitiesOnly yes"
    fi
    echo
  done < <(each_server)
  printf '%s\n' "${SSH_CONFIG_END}"
}

sync_ssh_config() {
  local config_file="${1:-${SSH_CONFIG_FILE}}"
  local config_dir
  local tmp_file
  local new_file
  local backup_file
  local line
  local inside_block=0

  config_dir="$(dirname "${config_file}")"
  mkdir -p "${config_dir}"
  [[ -f "${config_file}" ]] || : > "${config_file}"

  tmp_file="$(mktemp)"
  new_file="$(mktemp)"
  backup_file="${config_file}.bak"

  while IFS= read -r line || [[ -n "${line}" ]]; do
    if [[ "${line}" == "${SSH_CONFIG_BEGIN}" ]]; then
      inside_block=1
      continue
    fi
    if [[ "${line}" == "${SSH_CONFIG_END}" ]]; then
      inside_block=0
      continue
    fi
    if [[ ${inside_block} -eq 0 ]]; then
      printf '%s\n' "${line}" >> "${tmp_file}"
    fi
  done < "${config_file}"

  cp "${config_file}" "${backup_file}"
  cat "${tmp_file}" > "${new_file}"
  if [[ -s "${new_file}" ]]; then
    printf '\n' >> "${new_file}"
  fi
  build_managed_ssh_config_block >> "${new_file}"
  mv "${new_file}" "${config_file}"
  chmod 600 "${config_file}" 2>/dev/null || true
  rm -f "${tmp_file}"

  echo "SSH 配置已同步: ${config_file}"
  echo "备份文件: ${backup_file}"
}

ensure_code_cli() {
  local candidate
  local -a candidates=(
    "${CODE_BIN}"
    "code"
    "/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code"
    "${HOME}/Applications/Visual Studio Code.app/Contents/Resources/app/bin/code"
    "/Applications/Visual Studio Code - Insiders.app/Contents/Resources/app/bin/code"
    "${HOME}/Applications/Visual Studio Code - Insiders.app/Contents/Resources/app/bin/code"
  )

  for candidate in "${candidates[@]}"; do
    [[ -z "${candidate}" ]] && continue
    if command -v "${candidate}" >/dev/null 2>&1; then
      RESOLVED_CODE_BIN="$(command -v "${candidate}")"
      return 0
    fi
    if [[ -x "${candidate}" ]]; then
      RESOLVED_CODE_BIN="${candidate}"
      return 0
    fi
  done

  echo "没找到 VS Code 命令行工具。"
  echo "已尝试: ${CODE_BIN}、code，以及常见 macOS 安装路径。"
  echo "你可以："
  echo "1. 在 VS Code 命令面板执行: Shell Command: Install 'code' command in PATH"
  echo "2. 或者设置环境变量 VPSCTL_CODE_BIN 指向 code 的实际路径"
  return 1
}

resolve_remote_home() {
  local target="$1"
  local line

  if ! line="$(find_server "${target}")"; then
    echo "没找到服务器: ${target}" >&2
    return 1
  fi

  capture_remote_command "${line}" "printf '%s\n' \"\$HOME\"" "serial"
  if [[ ${CAPTURED_REMOTE_STATUS} -ne 0 ]]; then
    echo "读取远程 HOME 目录失败: ${target}" >&2
    [[ -n "${CAPTURED_REMOTE_OUTPUT}" ]] && echo "${CAPTURED_REMOTE_OUTPUT}" >&2
    return 1
  fi
  printf '%s\n' "$(trim "${CAPTURED_REMOTE_OUTPUT}")"
}

resolve_remote_code_path() {
  local target="$1"
  local requested_path="${2:-}"
  local remote_home

  remote_home="$(resolve_remote_home "${target}")" || return 1

  if [[ -z "${requested_path}" ]]; then
    printf '%s\n' "${remote_home}"
    return 0
  fi

  case "${requested_path}" in
    /|rootfs|fs)
      printf '%s\n' "/"
      return 0
      ;;
    home)
      printf '%s\n' "/home"
      return 0
      ;;
    root)
      printf '%s\n' "/root"
      return 0
      ;;
    etc)
      printf '%s\n' "/etc"
      return 0
      ;;
    var)
      printf '%s\n' "/var"
      return 0
      ;;
    opt)
      printf '%s\n' "/opt"
      return 0
      ;;
    srv)
      printf '%s\n' "/srv"
      return 0
      ;;
    usr)
      printf '%s\n' "/usr"
      return 0
      ;;
  esac

  if [[ "${requested_path}" == /* ]]; then
    printf '%s\n' "${requested_path}"
    return 0
  fi

  if [[ "${requested_path}" == "~" ]]; then
    printf '%s\n' "${remote_home}"
    return 0
  fi

  if [[ "${requested_path}" == "~/"* ]]; then
    printf '%s\n' "${remote_home}/${requested_path#~/}"
    return 0
  fi

  printf '%s\n' "${remote_home}/${requested_path}"
}

backup_remote_path() {
  local target="$1"
  local requested_path="$2"
  local line
  local resolved_path
  local backup_command

  if ! line="$(find_server "${target}")"; then
    echo "没找到服务器: ${target}"
    return 1
  fi

  resolved_path="$(resolve_remote_code_path "${target}" "${requested_path}")" || return 1

  if [[ "${resolved_path}" == "/" || "${resolved_path}" == "/root" || "${resolved_path}" == "/home" ]]; then
    echo "这个路径太大了，不建议整目录直接备份: ${resolved_path}"
    echo "请改成更具体的目录或文件，例如 /etc/nginx 或 /opt/app/.env"
    return 1
  fi

  backup_command="$(cat <<EOF
set -e
target_path=$(quote_for_single_shell "${resolved_path}")
backup_base="\$HOME/.vps-pilot/backups"
timestamp="\$(date '+%Y%m%d-%H%M%S')"
safe_name="\$(printf '%s' "\$target_path" | tr '/ ' '__')"
mkdir -p "\$backup_base"
if [ -d "\$target_path" ]; then
  archive_path="\$backup_base/\${timestamp}-\${safe_name}.tar.gz"
  tar -czf "\$archive_path" -C "\$(dirname "\$target_path")" "\$(basename "\$target_path")"
  printf 'backup: %s\n' "\$archive_path"
elif [ -f "\$target_path" ]; then
  dir_path="\$backup_base/\${timestamp}-\${safe_name}"
  mkdir -p "\$dir_path"
  cp -a "\$target_path" "\$dir_path/"
  printf 'backup: %s\n' "\$dir_path"
else
  echo "目标路径不存在: \$target_path" >&2
  exit 1
fi
EOF
)"

  capture_remote_command "${line}" "${backup_command}" "serial"
  if [[ ${CAPTURED_REMOTE_STATUS} -ne 0 ]]; then
    echo "备份失败: ${target}:${resolved_path}"
    [[ -n "${CAPTURED_REMOTE_OUTPUT}" ]] && echo "${CAPTURED_REMOTE_OUTPUT}"
    return 1
  fi

  echo "已创建备份: ${target}:${resolved_path}"
  echo "${CAPTURED_REMOTE_OUTPUT}"
}

open_remote_in_code() {
  local target="$1"
  local requested_path="${2:-}"
  local resolved_path

  ensure_code_cli || return 1
  sync_ssh_config "${SSH_CONFIG_FILE}"
  resolved_path="$(resolve_remote_code_path "${target}" "${requested_path}")" || return 1

  if [[ ${CODE_BACKUP_BEFORE_OPEN:-0} -eq 1 ]]; then
    backup_remote_path "${target}" "${resolved_path}" || return 1
  fi

  if [[ "${resolved_path}" == /etc* || "${resolved_path}" == /opt* || "${resolved_path}" == /var* ]]; then
    echo "提示: 这是生产味很重的目录，Remote-SSH 保存就是直接改远程文件。"
    echo "建议先执行: vps backup ${target} ${resolved_path}"
  fi

  echo "正在打开 VS Code Remote-SSH: ${target}:${resolved_path}"
  "${RESOLVED_CODE_BIN}" --remote "ssh-remote+${target}" "${resolved_path}"
}

parse_ssh_config_args() {
  SSH_CONFIG_ACTION="sync"
  SSH_CONFIG_TARGET_FILE="${SSH_CONFIG_FILE}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      sync|show)
        SSH_CONFIG_ACTION="$1"
        ;;
      --file)
        shift
        [[ $# -gt 0 ]] || { echo "--file 后面要跟路径"; return 1; }
        SSH_CONFIG_TARGET_FILE="$(expand_home "$1")"
        ;;
      *)
        echo "用法: vps ssh-config [sync|show] [--file path]"
        return 1
        ;;
    esac
    shift
  done
}

