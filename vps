validate_config() {
  local line
  local lineno=0
  local errors=0
  local seen_total=0
  local field_count
  local -a seen_names=()
  local seen name_item

  while IFS= read -r line || [[ -n "${line}" ]]; do
    lineno=$((lineno + 1))
    line="$(trim "${line}")"
    [[ -z "${line}" || "${line}" == \#* ]] && continue

    field_count="$(awk -F'|' '{print NF}' <<<"${line}")"
    if [[ "${field_count}" -ne 5 ]]; then
      echo "第 ${lineno} 行字段数量不对，应该是 5 段。"
      errors=$((errors + 1))
      continue
    fi

    parse_server "${line}"

    if [[ -z "${SERVER_NAME}" || -z "${SERVER_USER}" || -z "${SERVER_HOST}" ]]; then
      echo "第 ${lineno} 行有空字段，名称、用户、主机都必须填。"
      errors=$((errors + 1))
    fi

    if ! [[ "${SERVER_PORT}" =~ ^[0-9]+$ ]] || (( SERVER_PORT < 1 || SERVER_PORT > 65535 )); then
      echo "第 ${lineno} 行端口不合法: ${SERVER_PORT}"
      errors=$((errors + 1))
    fi

    if [[ "${SERVER_KEY}" != "-" && ! -f "${SERVER_KEY}" ]]; then
      echo "第 ${lineno} 行私钥文件不存在: ${SERVER_KEY}"
      errors=$((errors + 1))
    fi

    seen=0
    if [[ ${seen_total} -gt 0 ]]; then
      for name_item in "${seen_names[@]}"; do
        if [[ "${name_item}" == "${SERVER_NAME}" ]]; then
          seen=1
          break
        fi
      done
    fi
    if [[ ${seen} -eq 1 ]]; then
      echo "第 ${lineno} 行服务器名称重复: ${SERVER_NAME}"
      errors=$((errors + 1))
    else
      seen_names+=("${SERVER_NAME}")
      seen_total=$((seen_total + 1))
    fi
  done < "${CONFIG_FILE}"

  if [[ ${seen_total} -eq 0 ]]; then
    echo "配置文件里没有有效服务器。"
    return 1
  fi

  if [[ ${errors} -eq 0 ]]; then
    echo "配置校验通过，共 ${seen_total} 台服务器。"
    return 0
  fi

  echo "配置校验失败，共发现 ${errors} 个问题。"
  return 1
}

