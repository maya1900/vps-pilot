append_batch_history() {
  local cmd="$1"
  BATCH_HISTORY_ITEMS+=("${cmd}")
  BATCH_HISTORY_COUNT=$((BATCH_HISTORY_COUNT + 1))
  printf '%s\n' "${cmd}" >> "${HISTORY_FILE}"
}

show_batch_history() {
  local i

  if [[ ${BATCH_HISTORY_COUNT} -eq 0 ]]; then
    echo "当前会话还没有历史命令。"
    return 0
  fi

  echo "本次会话历史:"
  for ((i=0; i<${BATCH_HISTORY_COUNT}; i++)); do
    printf '  [%d] %s\n' "$((i + 1))" "${BATCH_HISTORY_ITEMS[$i]}"
  done
}

resolve_history_reference() {
  local token="$1"
  local idx

  if [[ ${BATCH_HISTORY_COUNT} -eq 0 ]]; then
    echo "当前会话还没有可重跑的命令。" >&2
    return 1
  fi

  if [[ "${token}" == "!!" ]]; then
    printf '%s\n' "${BATCH_HISTORY_ITEMS[$((BATCH_HISTORY_COUNT - 1))]}"
    return 0
  fi

  if [[ "${token}" =~ ^![0-9]+$ ]]; then
    idx="${token#!}"
    if (( idx < 1 || idx > BATCH_HISTORY_COUNT )); then
      echo "历史编号超出范围: ${idx}" >&2
      return 1
    fi
    printf '%s\n' "${BATCH_HISTORY_ITEMS[$((idx - 1))]}"
    return 0
  fi

  return 1
}

batch_console() {
  local target="$1"
  local mode="${2:-serial}"
  local session_kind="${3:-host}"
  local container_name="${4:-}"
  local prompt mode_label remote_cmd
  local translated_cmd=""
  local session_label=""
  local wrapped_cmd=""

  BATCH_HISTORY_COUNT=0
  BATCH_HISTORY_ITEMS=()
  : > "${HISTORY_FILE}"

  mode_label="${mode}"
  session_label="${target}"
  if [[ "${session_kind}" == "container" ]]; then
    session_label="${target}/${container_name}"
    echo "进入容器批量命令会话，目标: ${target}，容器: ${container_name}"
  else
    echo "进入批量命令会话，目标: ${target}，模式: ${mode_label}"
  fi
  print_batch_console_help "${session_kind}"
  echo
  print_batch_shortcuts "${session_kind}"
  echo

  while true; do
    if [[ "${session_kind}" == "container" ]]; then
      prompt="cbatch(${session_label})> "
    else
      prompt="batch(${session_label}/${mode_label})> "
    fi
    if [[ -t 0 && -t 1 ]]; then
      if ! read -e -r -p "${prompt}" remote_cmd; then
        echo
        break
      fi
    elif ! read -r -p "${prompt}" remote_cmd; then
      echo
      break
    fi

    remote_cmd="$(trim "${remote_cmd}")"
    [[ -z "${remote_cmd}" ]] && continue

    case "${remote_cmd}" in
      :q|:quit|exit|quit)
        break
        ;;
      :help|help)
        print_batch_console_help "${session_kind}"
        echo
        print_batch_shortcuts "${session_kind}"
        echo
        continue
        ;;
      :history)
        show_batch_history
        echo
        continue
        ;;
      :shortcuts)
        print_batch_shortcuts "${session_kind}"
        echo
        continue
        ;;
    esac

    translated_cmd=""
    case "${remote_cmd}" in
      '!!'|![0-9]*)
        if translated_cmd="$(resolve_history_reference "${remote_cmd}")"; then
          remote_cmd="${translated_cmd}"
          echo "重跑: ${remote_cmd}"
        else
          echo
          continue
        fi
        ;;
      *)
        if translated_cmd="$(batch_shortcut_command "${session_kind}" "${remote_cmd}")"; then
          remote_cmd="${translated_cmd}"
          echo "快捷词展开: ${remote_cmd}"
        fi
        ;;
    esac

    append_batch_history "${remote_cmd}"
    wrapped_cmd="${remote_cmd}"
    if [[ "${session_kind}" == "container" ]]; then
      wrapped_cmd="$(wrap_container_exec_command "${container_name}" "${remote_cmd}")"
    fi
    run_for_target "${target}" "${wrapped_cmd}" "${mode}"
  done
}

