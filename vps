    "$(style_text "${STYLE_ACCENT}" "名称")" \
    "$(style_text "${STYLE_ACCENT}" "用户")" \
    "$(style_text "${STYLE_ACCENT}" "主机")" \
    "$(style_text "${STYLE_ACCENT}" "端口")" \
    "$(style_text "${STYLE_ACCENT}" "密钥")"
