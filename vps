select_container_for_target() {
  local target="$1"
  local choice
  local picked_line
  local name image status

  get_containers_for_target "${target}" || return 1
  if [[ ${#CONTAINER_LINES[@]} -eq 0 ]]; then
    echo "${target} 上没有容器，没法进入容器会话。"
    return 1
  fi

  echo "可选容器:"
  print_containers_for_target "${target}" "1" || return 1
  echo
  read -r -p "输入容器序号或容器名: " choice
  choice="$(trim "${choice}")"
  [[ -z "${choice}" ]] && { echo "没输入容器。"; return 1; }

  if [[ "${choice}" =~ ^[0-9]+$ ]]; then
    if (( choice < 1 || choice > ${#CONTAINER_LINES[@]} )); then
      echo "容器序号超出范围: ${choice}"
      return 1
    fi
    picked_line="${CONTAINER_LINES[$((choice - 1))]}"
    IFS='|' read -r name image status <<< "${picked_line}"
    SELECTED_CONTAINER="${name}"
    return 0
  fi

  local item
  for item in "${CONTAINER_LINES[@]}"; do
    IFS='|' read -r name image status <<< "${item}"
    if [[ "${name}" == "${choice}" ]]; then
      SELECTED_CONTAINER="${name}"
      return 0
    fi
  done

  echo "没找到这个容器: ${choice}"
  return 1
}

run_serial_batch() {
  local remote_cmd="$1"
  shift
  local -a server_lines=("$@")
  local -a ok_names=()
  local -a failed_names=()
  local ok_total=0
  local failed_total=0
  local line
  local failed_list=""

  for line in "${server_lines[@]}"; do
    parse_server "${line}"
    if run_remote_command "${line}" "${remote_cmd}" "serial"; then
      ok_names+=("${SERVER_NAME}")
      ok_total=$((ok_total + 1))
    else
      failed_names+=("${SERVER_NAME}")
      failed_total=$((failed_total + 1))
    fi
  done

  if [[ ${failed_total} -gt 0 ]]; then
    failed_list="$(join_by_comma "${failed_names[@]}")"
  fi
  print_batch_summary "批量任务" "${ok_total}" "${failed_total}" "${failed_list}"
  [[ ${failed_total} -eq 0 ]]
}

run_parallel_batch() {
  local remote_cmd="$1"
  shift
  local -a server_lines=("$@")
  local temp_dir
  local -a pids=()
  local -a names=()
  local -a logs=()
  local -a ok_names=()
  local -a failed_names=()
  local ok_total=0
  local failed_total=0
  local line log_path status i
  local failed_list=""

  temp_dir="$(mktemp -d)"

  for line in "${server_lines[@]}"; do
    parse_server "${line}"
    log_path="${temp_dir}/${SERVER_NAME}.log"
    names+=("${SERVER_NAME}")
    logs+=("${log_path}")
    (
      run_remote_command "${line}" "${remote_cmd}" "parallel"
    ) >"${log_path}" 2>&1 &
    pids+=("$!")
  done

  for ((i=0; i<${#pids[@]}; i++)); do
    set +e
    wait "${pids[$i]}"
    status=$?
    set -e
    cat "${logs[$i]}"
    if [[ ${status} -eq 0 ]]; then
      ok_names+=("${names[$i]}")
      ok_total=$((ok_total + 1))
    else
      failed_names+=("${names[$i]}")
      failed_total=$((failed_total + 1))
    fi
  done

  rm -rf "${temp_dir}"
  if [[ ${failed_total} -gt 0 ]]; then
    failed_list="$(join_by_comma "${failed_names[@]}")"
  fi
  print_batch_summary "并发批量任务" "${ok_total}" "${failed_total}" "${failed_list}"
  [[ ${failed_total} -eq 0 ]]
}

run_for_target() {
  local target="$1"
  local remote_cmd="$2"
  local mode="${3:-serial}"
  local line

  if [[ "${target}" == "all" ]]; then
    local -a server_lines=()
    while IFS= read -r line; do
      server_lines+=("${line}")
    done < <(each_server)

    if [[ "${mode}" == "parallel" ]]; then
      run_parallel_batch "${remote_cmd}" "${server_lines[@]}"
    else
      run_serial_batch "${remote_cmd}" "${server_lines[@]}"
    fi
    return $?
  fi

  if ! line="$(find_server "${target}")"; then
    echo "没找到服务器: ${target}"
    exit 1
  fi
  run_remote_command "${line}" "${remote_cmd}" "${mode}"
}

