fi

net_dev_line="$(awk -F'[: ]+' '$1 !~ /^(lo|Inter|face)$/ {rx += $3; tx += $11} END {print rx "|" tx}' /proc/net/dev 2>/dev/null)"
IFS='|' read -r rx_bytes tx_bytes <<<"${net_dev_line}"
