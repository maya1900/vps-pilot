status_remote_script() {
  cat <<'EOF'
echo "hostname: $(hostname)"
echo "time: $(date '+%F %T %Z')"
echo "uptime: $(uptime)"
echo "disk (/):"
df -h /
echo "memory:"
free -h 2>/dev/null || awk '/MemTotal|MemAvailable/ {print}' /proc/meminfo 2>/dev/null || echo "memory info unavailable"
echo "load:"
cat /proc/loadavg 2>/dev/null | awk '{print $1, $2, $3}' || echo "load unavailable"
echo "services:"
if command -v systemctl >/dev/null 2>&1; then
  for svc in sshd ssh nginx docker cron; do
    state="$(systemctl is-active "$svc" 2>/dev/null || true)"
    if [ -n "$state" ]; then
      printf '  %s: %s\n' "$svc" "$state"
    fi
  done
else
  echo "  systemctl unavailable"
fi
echo "public ip:"
if command -v curl >/dev/null 2>&1; then
  curl -fsS --max-time 4 ifconfig.me 2>/dev/null || curl -fsS --max-time 4 api.ipify.org 2>/dev/null || echo "unavailable"
else
  echo "curl unavailable"
fi
EOF
}

status_detail_remote_script() {
  cat <<'EOF'
#!/usr/bin/env bash
set +e

format_bytes_iec() {
  awk -v value="$1" 'BEGIN {
    split("B KB MB GB TB PB", units, " ");
    idx = 1;
    while (value >= 1024 && idx < 6) {
      value /= 1024;
      idx++;
    }
    if (idx == 1) {
      printf "%.0f%s", value, units[idx];
    } else {
      printf "%.2f%s", value, units[idx];
    }
  }'
}

format_uptime_pretty() {
  awk '{secs=$1; days=int(secs/86400); secs%=86400; hours=int(secs/3600); secs%=3600; mins=int(secs/60); printf "%d天 %d时 %d分", days, hours, mins}' /proc/uptime 2>/dev/null
}

format_hz_ghz() {
  awk -v value="$1" 'BEGIN { if (value == "" || value == 0) { print "-"; } else { printf "%.1f GHz", value / 1000 } }'
}

kv_print() {
  printf '%-16s %s\n' "$1" "$2"
}

hostname_value="$(hostname 2>/dev/null || echo "-")"
os_name="$(. /etc/os-release 2>/dev/null && printf '%s' "${PRETTY_NAME:-${NAME:-unknown}}")"
kernel_value="$(uname -r 2>/dev/null || echo "-")"
arch_value="$(uname -m 2>/dev/null || echo "-")"
cpu_model="$(awk -F: '/model name/ {gsub(/^[ \t]+/, "", $2); print $2; exit}' /proc/cpuinfo 2>/dev/null)"
[ -n "${cpu_model}" ] || cpu_model="$(lscpu 2>/dev/null | awk -F: '/Model name/ {gsub(/^[ \t]+/, "", $2); print $2; exit}')"
[ -n "${cpu_model}" ] || cpu_model="-"
cpu_cores="$(nproc 2>/dev/null || echo "-")"
cpu_freq_raw="$(awk -F: '/cpu MHz/ {gsub(/^[ \t]+/, "", $2); print $2; exit}' /proc/cpuinfo 2>/dev/null)"
[ -n "${cpu_freq_raw}" ] || cpu_freq_raw="$(lscpu 2>/dev/null | awk -F: '/CPU max MHz|CPU MHz/ {gsub(/^[ \t]+/, "", $2); print $2; exit}')"
cpu_freq_value="$(format_hz_ghz "${cpu_freq_raw}")"

read_cpu_stat() {
  awk '/^cpu / {print $2, $3, $4, $5, $6, $7, $8, $9, $10}' /proc/stat 2>/dev/null
}

read -r u1 n1 s1 i1 w1 irq1 sirq1 st1 g1 <<<"$(read_cpu_stat)"
sleep 0.5
read -r u2 n2 s2 i2 w2 irq2 sirq2 st2 g2 <<<"$(read_cpu_stat)"

if [ -n "${u1}" ] && [ -n "${u2}" ]; then
  idle_delta=$(( (i2 + w2) - (i1 + w1) ))
  total1=$((u1 + n1 + s1 + i1 + w1 + irq1 + sirq1 + st1 + g1))
  total2=$((u2 + n2 + s2 + i2 + w2 + irq2 + sirq2 + st2 + g2))
  total_delta=$((total2 - total1))
  if [ "${total_delta}" -gt 0 ] 2>/dev/null; then
    cpu_usage="$(awk -v idle="${idle_delta}" -v total="${total_delta}" 'BEGIN { printf "%.0f%%", ((total - idle) / total) * 100 }')"
  else
    cpu_usage="-"
  fi
else
  cpu_usage="-"
fi

read -r load1 load5 load15 _ <<<"$(awk '{print $1, $2, $3, $4}' /proc/loadavg 2>/dev/null)"
[ -n "${load1}" ] || load1="-"
[ -n "${load5}" ] || load5="-"
[ -n "${load15}" ] || load15="-"

tcp_count="$(ss -tan 2>/dev/null | tail -n +2 | wc -l | awk '{print $1}')"
udp_count="$(ss -uan 2>/dev/null | tail -n +2 | wc -l | awk '{print $1}')"
[ -n "${tcp_count}" ] || tcp_count="-"
[ -n "${udp_count}" ] || udp_count="-"

mem_total_mb="$(free -m 2>/dev/null | awk '/^Mem:/ {print $2}')"
mem_used_mb="$(free -m 2>/dev/null | awk '/^Mem:/ {print $3}')"
swap_total_mb="$(free -m 2>/dev/null | awk '/^Swap:/ {print $2}')"
swap_used_mb="$(free -m 2>/dev/null | awk '/^Swap:/ {print $3}')"
if [ -n "${mem_total_mb}" ] && [ "${mem_total_mb}" -gt 0 ] 2>/dev/null; then
  mem_percent="$(awk -v used="${mem_used_mb}" -v total="${mem_total_mb}" 'BEGIN { printf "%.2f%%", (used / total) * 100 }')"
  mem_value="${mem_used_mb}M/${mem_total_mb}M (${mem_percent})"
else
  mem_value="-"
fi
if [ -n "${swap_total_mb}" ] && [ "${swap_total_mb}" -gt 0 ] 2>/dev/null; then
  swap_percent="$(awk -v used="${swap_used_mb}" -v total="${swap_total_mb}" 'BEGIN { printf "%.0f%%", (used / total) * 100 }')"
  swap_value="${swap_used_mb}M/${swap_total_mb}M (${swap_percent})"
else
  swap_value="0M/0M (0%)"
fi

disk_line="$(df -h / 2>/dev/null | awk 'NR==2 {print $3 "|" $2 "|" $5}')"
if [ -n "${disk_line}" ]; then
  IFS='|' read -r disk_used disk_total disk_percent <<<"${disk_line}"
  disk_value="${disk_used}/${disk_total} (${disk_percent})"
else
