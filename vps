    esac
    echo
    read -r -n 1 -s -p "按任意键返回菜单..." _unused
    echo
    echo
  done
}

normalize_cmd() {
  case "${1:-}" in
    "" )
      printf '%s\n' "menu"
      ;;
    list|ls )
      printf '%s\n' "list"
      ;;
    ssh|login )
      printf '%s\n' "ssh"
      ;;
    code|vscode )
      printf '%s\n' "code"
      ;;
    backup|snapshot )
      printf '%s\n' "backup"
      ;;
    docker )
      printf '%s\n' "containers"
      ;;
    ssh-config|sshconfig )
      printf '%s\n' "ssh-config"
      ;;
    run|exec )
      printf '%s\n' "run"
      ;;
    status )
      printf '%s\n' "status"
      ;;
    check )
      printf '%s\n' "check"
      ;;
    doctor|diag|diagnose )
      printf '%s\n' "doctor"
      ;;
    batch|console )
      printf '%s\n' "batch"
      ;;
    containers|container-list )
      printf '%s\n' "containers"
      ;;
    cbatch|container-batch )
      printf '%s\n' "cbatch"
      ;;
    update )
      printf '%s\n' "update"
      ;;
    upgrade )
      printf '%s\n' "upgrade"
      ;;
    reboot )
      printf '%s\n' "reboot"
      ;;
    copy-key|copykey )
      printf '%s\n' "copy-key"
      ;;
    validate )
      printf '%s\n' "validate"
      ;;
    version|--version|-V )
      printf '%s\n' "version"
      ;;
    menu )
      printf '%s\n' "menu"
      ;;
    help|-h|--help )
      printf '%s\n' "help"
      ;;
    * )
      printf '%s\n' "$1"
      ;;
  esac
}

main() {
  ensure_config

  local original_cmd="${1:-}"
  local cmd
  cmd="$(normalize_cmd "${original_cmd}")"

  case "${cmd}" in
    list)
      list_servers
      ;;
    ssh)
      [[ $# -ge 2 ]] || { echo "用法: vps ssh <name>"; exit 1; }
      ssh_into_server "$2"
      ;;
    code)
      parse_code_args "${@:2}" || exit 1
      open_remote_in_code "${CODE_TARGET}" "${CODE_PATH}"
      ;;
    backup)
      parse_backup_args "${@:2}" || exit 1
      backup_remote_path "${BACKUP_TARGET}" "${BACKUP_PATH}"
      ;;
    ssh-config)
      parse_ssh_config_args "${@:2}" || exit 1
      case "${SSH_CONFIG_ACTION}" in
        sync)
          sync_ssh_config "${SSH_CONFIG_TARGET_FILE}"
          ;;
        show)
          print_ssh_config_preview
          ;;
      esac
      ;;
    run)
      parse_run_args "${@:2}" || exit 1
      if [[ "${RUN_MODE}" == "parallel" && "${RUN_TARGET}" != "all" ]]; then
        echo "并发模式主要给 all 用，单台机器没必要开并发。"
      fi
      run_for_target "${RUN_TARGET}" "${RUN_COMMAND}" "${RUN_MODE}"
      ;;
    status)
      parse_target_mode_args "${@:2}" || exit 1
      if [[ "${PARSED_TARGET}" == "all" ]]; then
        run_for_target "${PARSED_TARGET}" "$(status_remote_script)" "${PARSED_MODE}"
      else
        run_for_target "${PARSED_TARGET}" "$(status_detail_remote_script)" "serial"
      fi
      ;;
    check)
      parse_target_mode_args "${@:2}" || exit 1
      run_for_target "${PARSED_TARGET}" "$(check_remote_script)" "${PARSED_MODE}"
      ;;
    doctor)
      parse_doctor_args "${@:2}" || exit 1
      doctor_target "${DOCTOR_TARGET}" "${DOCTOR_SUBJECT}"
      ;;
    batch)
      parse_target_mode_args "${@:2}" || exit 1
      batch_console "${PARSED_TARGET}" "${PARSED_MODE}" "host"
      ;;
    containers)
      parse_containers_args "${@:2}" || exit 1
      print_containers_for_target "${CONTAINERS_TARGET}"
      ;;
    cbatch)
      parse_cbatch_args "${@:2}" || exit 1
      if [[ -z "${CBATCH_CONTAINER}" ]]; then
        if [[ -t 0 && -t 1 ]]; then
          select_container_for_target "${CBATCH_TARGET}" || exit 1
          CBATCH_CONTAINER="${SELECTED_CONTAINER}"
        else
          echo "用法: vps cbatch <name> [container]"
          echo "非交互场景下请明确传容器名，或者先执行: vps containers <name>"
          exit 1
        fi
      fi
      batch_console "${CBATCH_TARGET}" "serial" "container" "${CBATCH_CONTAINER}"
      ;;
    update)
      parse_target_mode_args "${@:2}" || exit 1
      run_for_target "${PARSED_TARGET}" "sudo apt update" "${PARSED_MODE}"
      ;;
    upgrade)
      parse_target_mode_args "${@:2}" || exit 1
      run_for_target "${PARSED_TARGET}" "sudo apt update && sudo apt -y upgrade" "${PARSED_MODE}"
      ;;
    reboot)
      confirm_reboot "${2:-all}"
      run_for_target "${2:-all}" "sudo reboot" "serial"
      ;;
    copy-key)
      [[ $# -ge 2 ]] || { echo "用法: vps copy-key <name>"; exit 1; }
      copy_key "$2"
      ;;
    validate)
      validate_config
      ;;
    version)
      print_version
      ;;
    menu)
      menu
      ;;
    help)
      interactive_help
      ;;
    *)
      echo "不认识这个命令: ${original_cmd}"
      echo
      interactive_help
      exit 1
      ;;
  esac
}

main "$@"
