style_text() {
  local style="$1"
  shift
  printf '%s%s%s' "${style}" "$*" "${STYLE_RESET}"
}

print_rule() {
  printf '%s\n' "$(style_text "${STYLE_MUTED}" "------------------------------------------------------------")"
}

print_section_title() {
  local title="$1"
  printf '%s %s\n' "$(style_text "${STYLE_LABEL}" "[*]")" "$(style_text "${STYLE_VALUE}" "${title}")"
}

format_status_label() {
  local text="$1"
  local state="${2:-info}"
  local style="${STYLE_ACCENT}"
  case "${state}" in
    ok) style="${STYLE_OK}" ;;
    warn) style="${STYLE_WARN}" ;;
    fail) style="${STYLE_FAIL}" ;;
    info) style="${STYLE_ACCENT}" ;;
  esac
  printf '%s' "$(style_text "${style}" "${text}")"
}

