  local name image status

  if [[ "${skip_fetch}" != "1" ]]; then
    get_containers_for_target "${target}" || return 1
  fi
  if [[ ${#CONTAINER_LINES[@]} -eq 0 ]]; then
    echo "${target} 上没有容器。"
    return 0
  fi

  print_section_title "容器列表 · ${target}"
  printf '%-4s %-24s %-28s %s\n' "序号" "容器名" "镜像" "状态"
  print_rule
  local idx=1
  for item in "${CONTAINER_LINES[@]}"; do
    IFS='|' read -r name image status <<< "${item}"
    printf '%-4s %-24s %-28s %s\n' "${idx}" "${name}" "${image}" "${status}"
    idx=$((idx + 1))
