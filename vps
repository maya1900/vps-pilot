echo "-- failed services --"
if command -v systemctl >/dev/null 2>&1; then
  systemctl --failed --no-pager 2>/dev/null || true
else
  echo "systemctl unavailable"
fi
echo
echo "## 最近错误"
if command -v journalctl >/dev/null 2>&1; then
  journalctl -p err -n 60 --no-pager 2>&1 || true
else
  echo "journalctl unavailable"
fi
echo
echo "## 网络监听"
ss -tulpn 2>/dev/null | head -n 40 || netstat -tulpn 2>/dev/null | head -n 40 || echo "port info unavailable"
echo
echo "## Docker 概览"
if command -v docker >/dev/null 2>&1; then
  docker ps -a --format 'table {{.Names}}\t{{.Status}}\t{{.Image}}' 2>/dev/null || true
else
  echo "docker unavailable"
fi

if [ -n "\${subject}" ]; then
  echo
  echo "## 指定对象"
  echo "subject: \${subject}"
  if command -v systemctl >/dev/null 2>&1; then
    echo "-- systemctl status \${subject} --"
    systemctl status "\${subject}" --no-pager -l 2>&1 | tail -n 80 || true
    echo "-- journalctl -u \${subject} --"
    journalctl -u "\${subject}" -n 80 --no-pager 2>&1 || true
  fi
